{
  "manifest_version": 3,
  "name": "LinkedIn Comment Submit",
  "version": "1.0.0",
  "description": "Press Cmd+Enter (Mac) or Ctrl+Enter (Win/Linux) to post a LinkedIn comment.",
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
